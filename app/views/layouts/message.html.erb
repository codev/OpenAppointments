<%# Port of EA layouts/message_layout.php. %>
<!doctype html>
<html lang="<%= script_vars[:language_code] %>">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <meta name="theme-color" content="#39824f">
    <meta name="google" content="notranslate">

    <%= yield :meta %>

    <title><%= vars(:page_title) %> | OpenAppointments</title>

    <link rel="icon" type="image/svg+xml" href="<%= image_path("logo.svg") %>">
    <link rel="icon" type="image/x-icon" href="<%= image_path("favicon.ico") %>">
    <link rel="icon" sizes="192x192" href="<%= image_path('logo.png') %>">

    <%= stylesheet_link_tag "themes/#{setting('theme', 'nice').presence || 'nice'}", "general" %>

    <%= render "shared/brand_style" %>

    <%= yield :styles %>
</head>
<body>
<div id="main" class="container min-vh-100">
    <div class="row wrapper min-vh-100 justify-content-center align-items-center py-3">
        <div id="message-frame" class="col-12 col-md-8 col-lg-6 my-auto frame-container text-center bg-body rounded shadow p-4 p-md-5">

            <%= yield %>

            <div class="mt-2">
                <small>
                    Powered by
                    <a href="https://github.com/codev/OpenAppointments">OpenAppointments</a>

                    <% if vars(:legal_notice_url).present? %>
                        <span class="mx-1">|</span>
                        <a href="<%= vars(:legal_notice_url) %>" target="_blank"><%= lang('legal_notice') %></a>
                    <% end %>

                    <% if vars(:imprint_url).present? %>
                        <span class="mx-1">|</span>
                        <a href="<%= vars(:imprint_url) %>" target="_blank"><%= lang('imprint') %></a>
                    <% end %>
                </small>

                <% if vars(:display_login_button).to_s == "1" %>
                    <div class="mt-3">
                        <a class="backend-link badge bg-primary text-decoration-none px-2 d-inline-block p-1"
                           href="<%= session[:user_id] ? "/calendar" : "/login" %>"
                           style="min-width: 120px;">
                            <i class="fas fa-sign-in-alt me-2"></i>
                            <%= session[:user_id] ? lang('backend_section') : lang('login') %>
                        </a>
                    </div>
                <% end %>
            </div>

        </div>
    </div>
</div>

<%= javascript_include_tag "vendor/jquery/jquery.min", "vendor/@popperjs-core/popper.min",
                           "vendor/bootstrap/bootstrap.min", "vendor/moment/moment.min",
                           "vendor/moment-timezone/moment-timezone-with-data.min",
                           "vendor/@fortawesome-fontawesome-free/fontawesome.min",
                           "vendor/@fortawesome-fontawesome-free/solid.min" %>

<%= ea_js "app", "utils/date", "utils/file", "utils/http", "utils/lang", "utils/message",
          "utils/string", "utils/url", "utils/validation" %>
<%= ea_js "layouts/message_layout", "http/localization_http_client" %>

<%= render "shared/js_vars_script" %>
<%= render "shared/js_lang_script" %>

<%= yield :scripts %>

</body>
</html>
