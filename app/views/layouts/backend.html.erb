<%# Port of EA layouts/backend_layout.php. %>
<!doctype html>
<html lang="<%= script_vars[:language_code] %>">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <meta name="theme-color" content="#39824f">
    <meta name="google" content="notranslate">

    <%= yield :meta %>

    <title><%= vars(:page_title) || lang('backend_section') %> | OpenAppointments</title>

    <link rel="icon" type="image/svg+xml" href="<%= image_path("logo.svg") %>">
    <link rel="icon" type="image/x-icon" href="<%= image_path("favicon.ico") %>">
    <link rel="icon" sizes="192x192" href="<%= image_path('logo.png') %>">

    <%= stylesheet_link_tag "vendor/trumbowyg/trumbowyg.min", "vendor/select2/select2.min",
                            "vendor/flatpickr/flatpickr.min", "vendor/flatpickr/material_green.min" %>
    <%= stylesheet_link_tag "themes/#{setting('theme', 'default').presence || 'default'}", "general", "backend" %>

    <%= render "shared/company_color_style", company_color: setting('company_color') %>

    <%= yield :styles %>
</head>
<body class="d-flex flex-column h-100">

<main class="flex-shrink-0">

    <%= render "shared/backend_header", active_menu: vars(:active_menu) %>

    <%= yield %>

</main>

<%= render "shared/backend_footer", user_display_name: vars(:user_display_name) %>

<%= javascript_include_tag "vendor/jquery/jquery.min", "vendor/@popperjs-core/popper.min",
                           "vendor/bootstrap/bootstrap.min", "vendor/moment/moment.min",
                           "vendor/moment-timezone/moment-timezone-with-data.min",
                           "vendor/@fortawesome-fontawesome-free/fontawesome.min",
                           "vendor/@fortawesome-fontawesome-free/solid.min",
                           "vendor/tippy.js/tippy-bundle.umd.min", "vendor/trumbowyg/trumbowyg.min",
                           "vendor/select2/select2.min", "vendor/flatpickr/flatpickr.min" %>

<%= ea_js "app", "utils/date", "utils/file", "utils/http", "utils/lang", "utils/message",
          "utils/pagination", "utils/string", "utils/url", "utils/validation" %>
<%= ea_js "layouts/backend_layout", "http/localization_http_client" %>

<%= render "shared/js_vars_script" %>
<%= render "shared/js_lang_script" %>

<%= yield :scripts %>

</body>
</html>
