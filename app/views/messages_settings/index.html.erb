<div id="messages-settings-page" class="container backend-page py-3">
    <div class="row">
        <div class="col-sm-3">
            <%= render "shared/messages_nav" %>
        </div>
        <div id="messages-settings" class="col-sm-9">
            <form>
                <fieldset>
                    <div class="d-flex justify-content-between align-items-center border-bottom mb-4 py-2">
                        <h4 class="mb-0 fw-light">
                            <%= lang('settings') %>
                        </h4>

                        <% if can?(:edit, :system_settings) %>
                            <button type="button" id="save-settings" class="btn btn-primary">
                                <i class="fas fa-check-square me-2"></i>
                                <%= lang('save') %>
                            </button>
                        <% end %>
                    </div>

                    <div class="row">
                        <div class="col-12 col-md-8">
                            <div class="form-check form-switch mb-3">
                                <input type="checkbox" class="form-check-input" id="messages-enabled"
                                       data-field="messages_enabled">
                                <label class="form-check-label" for="messages-enabled">
                                    <%= lang('messages_enabled') %>
                                </label>
                                <div class="form-text text-muted">
                                    <small>
                                        <%= lang('messages_enabled_hint') %>
                                    </small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="messages-retention-days">
                                    <%= lang('messages_retention_days') %>
                                </label>
                                <input type="number" min="0" id="messages-retention-days" class="form-control"
                                       data-field="messages_retention_days">
                                <div class="form-text text-muted">
                                    <small>
                                        <%= lang('messages_retention_days_hint') %>
                                    </small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="messages-email-subject">
                                    <%= lang('messages_email_subject') %>
                                </label>
                                <input type="text" id="messages-email-subject" class="form-control"
                                       data-field="messages_email_subject"
                                       placeholder="{{Company Name}} - Appointments">
                                <div class="form-text text-muted">
                                    <small>
                                        <%= lang('messages_email_subject_hint') %>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </form>
        </div>
    </div>
</div>

<% content_for :scripts do %>
    <%= ea_js "http/messages_settings_http_client", "pages/messages_settings" %>
<% end %>
