<%# Iframe embedding settings + copy-paste embed code. %>
<div class="container backend-page py-3" id="embed-settings-page">
    <div class="row">
        <div class="col-lg-3 col-xl-2">
            <%= render "shared/settings_nav" %>
        </div>

        <div class="col-lg-9 col-xl-10">
            <h4 class="py-3 mb-3 fw-light"><%= lang('embedding') %></h4>

            <div class="card card-body mb-4" style="max-width: 720px;">
                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="allow-iframe-embedding"
                               data-field="allow_iframe_embedding">
                        <label class="form-check-label" for="allow-iframe-embedding">
                            <%= lang('allow_iframe_embedding') %>
                        </label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="iframe-embed-origin">
                        <%= lang('iframe_embed_origin') %>
                    </label>
                    <input type="url" id="iframe-embed-origin" class="form-control"
                           data-field="iframe_embed_origin" placeholder="https://www.example.org" maxlength="256">
                </div>

                <div>
                    <button type="button" id="save-embed-settings" class="btn btn-primary">
                        <i class="fas fa-check-square me-2"></i>
                        <%= lang('save') %>
                    </button>
                </div>
            </div>

            <h5 class="fw-light mb-2"><%= lang('embed_code') %></h5>
            <p class="text-muted small"><%= lang('embed_hint') %></p>

            <div class="card card-body" style="max-width: 720px;">
<% embed_code = <<~HTML
     <iframe id="openappointments-booking" src="#{vars(:booking_url)}/" title="Book an appointment"
             style="width: 100%; min-height: 900px; border: 0;"></iframe>
     <script>
       window.addEventListener('message', function (event) {
         if (event.origin !== '#{vars(:booking_url)}') return;
         var data = event.data || {};
         if (data.type === 'openappointments:height') {
           document.getElementById('openappointments-booking').style.height = data.height + 'px';
         }
       });
     </script>
   HTML
%>
                <textarea id="embed-code" class="form-control font-monospace small" rows="12"
                          readonly><%= embed_code %></textarea>
                <div class="mt-2">
                    <button type="button" id="copy-embed-code" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-copy me-2"></i>
                        <%= lang('copy') %>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<% content_for :scripts do %>
    <%= ea_js "pages/embed_settings" %>
<% end %>
