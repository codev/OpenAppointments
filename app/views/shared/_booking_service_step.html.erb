<%# Service selection page. Locals: available_services, frame_index, swap_link.
    Split out of EA's single service+provider step; can be page 1 or 2 (?first=provider). %>
<div id="wizard-frame-<%= frame_index %>" class="wizard-frame p-3 p-md-4"
     style="<%= frame_index == 1 ? 'visibility: hidden;' : 'display:none;' %>">
    <div class="frame-container py-3" style="min-height: 500px;">
        <h2 class="frame-title fw-light text-center mb-4 text-muted mt-md-5"><%= lang('select_service') %></h2>

        <% cards_mode = vars(:display_mode) == "cards" %>
        <div class="row frame-content">
            <div class="col col-lg-8 offset-md-2">
                <div class="mb-3">
                    <label for="select-service" class="fs-5 mb-2 <%= 'd-none' if cards_mode %>">
                        <strong><%= lang('service') %></strong>
                    </label>

                    <select id="select-service" class="form-select mb-4 <%= 'd-none' if cards_mode %>">
                        <option value="">
                            <%= lang('please_select') %>
                        </option>
                        <%# Group services by category, only if there is at least one service with a parent category. %>
                        <% has_category = available_services.any? { |service| service["service_category_id"].present? } %>
                        <% if has_category %>
                            <% grouped_services = available_services.select { |service| service["service_category_id"].present? }
                                                                    .group_by { |service| service["service_category_name"] } %>
                            <%# Uncategorized services go at the end of the list. %>
                            <% grouped_services["uncategorized"] = available_services.select { |service| service["service_category_id"].nil? } %>
                            <% grouped_services.each do |key, group| %>
                                <% next unless group.any? %>
                                <% group_label = key != "uncategorized" ? group.first["service_category_name"] : "Uncategorized" %>
                                <optgroup label="<%= group_label %>">
                                    <% group.each do |service| %>
                                        <option value="<%= service["id"] %>"><%= service["name"] %></option>
                                    <% end %>
                                </optgroup>
                            <% end %>
                        <% else %>
                            <% available_services.each do |service| %>
                                <option value="<%= service["id"] %>"><%= service["name"] %></option>
                            <% end %>
                        <% end %>
                    </select>
                </div>

                <% if cards_mode %>
                    <%
                      categories = vars(:available_categories)
                      uncategorized = available_services.select { |service| service["service_category_id"].nil? }
                      service_groups = available_services.group_by { |service| service["service_category_id"] }
                    %>
                    <% if categories.any? %>
                        <div id="category-cards" class="booking-cards row g-3 mb-4">
                            <% categories.each do |category| %>
                                <div class="col-6 col-md-4">
                                    <div class="booking-card card h-100 text-center" role="button" tabindex="0"
                                         data-category-id="<%= category["id"] %>">
                                        <% if category["picture_url"].present? %>
                                            <img src="<%= category["picture_url"] %>" class="card-img-top booking-card-picture" alt="">
                                        <% end %>
                                        <div class="card-body p-2">
                                            <h5 class="card-title fs-6 mb-0"><%= category["name"] %></h5>
                                        </div>
                                    </div>
                                </div>
                            <% end %>
                            <% if uncategorized.any? %>
                                <div class="col-6 col-md-4">
                                    <div class="booking-card card h-100 text-center" role="button" tabindex="0"
                                         data-category-id="">
                                        <div class="card-body p-2">
                                            <h5 class="card-title fs-6 mb-0">Uncategorized</h5>
                                        </div>
                                    </div>
                                </div>
                            <% end %>
                        </div>
                    <% end %>
                    <% service_groups.each do |category_id, services| %>
                        <div class="service-cards booking-cards row g-3 mb-4 <%= 'd-none' if categories.any? %>"
                             data-category-id="<%= category_id %>">
                            <% services.each do |service| %>
                                <div class="col-6 col-md-4">
                                    <div class="booking-card card h-100 text-center" role="button" tabindex="0"
                                         data-service-id="<%= service["id"] %>">
                                        <% if service["picture_url"].present? %>
                                            <img src="<%= service["picture_url"] %>" class="card-img-top booking-card-picture" alt="">
                                        <% end %>
                                        <div class="card-body p-2">
                                            <h5 class="card-title fs-6 mb-1"><%= service["name"] %></h5>
                                            <div class="small text-muted">
                                                <%= service["duration"] %> <%= lang('minutes') %>
                                                <% if service["price"].to_f.positive? %>
                                                    | <%= service["price"] %> <%= service["currency"] %>
                                                <% end %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% end %>
                        </div>
                    <% end %>
                <% end %>

                <div id="service-description" class="small overflow-auto shadow-none" style="max-height: 153px;">
                    <!-- JS -->
                </div>

                <% if swap_link %>
                    <div class="text-center mt-4">
                        <a class="swap-first-step small"
                           href="<%= url_for(request.query_parameters.merge("first" => "provider")) %>">
                            <%= lang('select_provider_first') %>
                        </a>
                    </div>
                <% end %>
            </div>
        </div>
    </div>

    <div class="command-buttons text-center my-3 mx-auto d-md-flex justify-content-md-between">
        <% if frame_index == 1 %>
            <span>&nbsp;</span>
        <% else %>
            <button type="button" id="button-back-2" class="btn button-back btn-outline-secondary" style="min-width: 120px; margin-right: 10px;"
                    data-step_index="2">
                <i class="fas fa-chevron-left me-2"></i>
                <%= lang('back') %>
            </button>
        <% end %>

        <button type="button" id="button-next-<%= frame_index %>" class="btn button-next btn-dark" style="min-width: 120px; margin-right: 10px;"
                data-step_index="<%= frame_index %>">
            <%= lang('next') %>
            <i class="fas fa-chevron-right ms-2"></i>
        </button>
    </div>
</div>
