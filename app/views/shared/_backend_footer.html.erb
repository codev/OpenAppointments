<%# Port of EA components/backend_footer.php. Locals: user_display_name. %>
<footer id="footer" class="d-lg-flex justify-content-lg-start align-items-lg-center p-2 text-center text-lg-left mt-auto bg-body border-top" style="font-size: 11px;">
    <div class="mb-3 me-lg-5 mb-lg-0">
        <img class="me-1" src="<%= image_path("logo-16x16.png") %>" alt="OpenAppointments Logo">

        <a href="https://github.com/codev/OpenAppointments" target="_blank">OpenAppointments</a>

        <span>v<%= EaHelper::VERSION %></span>
    </div>

    <div class="mb-3 me-lg-5 mb-lg-0">
        By <a href="https://codev.uk/" target="_blank">Codev</a> - Based on Easy!Appointments by <a href="https://alextselegidis.com" target="_blank">Alex Tselegidis</a>
    </div>

    <div class="mb-3 me-lg-5 mb-lg-0">
        <%= lang('licensed_under') %>
        <a href="https://www.gnu.org/licenses/agpl-3.0.en.html" target="_blank">
            AGPL-3.0
        </a>
    </div>

    <div class="mb-3 me-lg-5 mb-lg-0">
        <a href="/appointments">
            <%= lang('go_to_booking_page') %>
        </a>
    </div>

    <div class="ms-lg-auto">
      <span id="select-language" class="badge bg-dark">
        <i class="fas fa-language me-2"></i>
        <%= script_vars[:language].to_s.upcase_first %>
      </span>
    </div>
</footer>
