<%# Port of EA components/backend_header.php. Locals: active_menu. %>
<nav id="header" class="navbar navbar-expand-md navbar-dark bg-primary p-0">
    <div id="header-logo" class="navbar-brand p-1 lh-1">
        <img src="<%= image_path("logo.png") %>" alt="logo" class="float-start me-2" style="width: 45px; height: 45px;">
        <h6 class="mb-1 mt-1 fw-bold text-white" style="font-size: 15px;">OpenAppointments</h6>
        <small class="d-block text-white-50" style="font-size: 12px;">Online Appointment Scheduler</small>
    </div>

    <button type="button" class="navbar-toggler me-1" data-bs-toggle="collapse" data-bs-target="#header-menu">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div id="header-menu" class="collapse navbar-collapse flex-row-reverse px-2">
        <ul class="navbar-nav">
            <% hidden = can?(:view, :appointments) ? "" : "d-none" %>
            <% active = active_menu == "appointments" ? "active" : "" %>
            <li class="nav-item text-center <%= active + hidden %>" style="min-width: 100px;">
                <a href="/calendar<%= vars(:calendar_view) == "table" ? "?view=table" : "" %>"
                   class="nav-link text-white fw-light py-3 px-3"
                   data-tippy-content="<%= lang('manage_appointment_record_hint') %>">
                    <i class="fas fa-calendar-alt me-2"></i>
                    <%= lang('calendar') %>
                </a>
            </li>

            <% hidden = can?(:view, :customers) ? "" : "d-none" %>
            <% active = active_menu == "customers" ? "active" : "" %>
            <li class="nav-item text-center <%= active + hidden %>" style="min-width: 100px;">
                <a href="/customers" class="nav-link text-white fw-light py-3 px-3"
                   data-tippy-content="<%= lang('manage_customers_hint') %>">
                    <i class="fas fa-user-friends me-2"></i>
                    <%= lang('customers') %>
                </a>
            </li>

            <% hidden = can?(:view, :system_settings) ? "" : "d-none" %>
            <% active = active_menu == "messages" ? "active" : "" %>
            <li class="nav-item text-center <%= active + hidden %>" style="min-width: 100px;">
                <a href="/messages_settings" class="nav-link text-white fw-light py-3 px-3"
                   data-tippy-content="<%= lang('messages_hint') %>">
                    <i class="fas fa-envelope me-2"></i>
                    <%= lang('messages') %>
                </a>
            </li>

            <% hidden = can?(:view, :services) ? "" : "d-none" %>
            <% active = active_menu == "services" ? "active" : "" %>
            <li class="nav-item dropdown text-center <%= active + hidden %>" style="min-width: 100px;">
                <a class="nav-link dropdown-toggle text-white fw-light py-3 px-3" href="#" data-bs-toggle="dropdown"
                   data-tippy-content="<%= lang('manage_services_hint') %>">
                    <i class="fas fa-business-time me-2"></i>
                    <%= lang('services') %>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <a class="dropdown-item" href="/services">
                        <%= lang('services') %>
                    </a>
                    <a class="dropdown-item" href="/service_categories">
                        <%= lang('categories') %>
                    </a>
                </div>
            </li>

            <% hidden = can?(:view, :users) ? "" : "d-none" %>
            <% active = active_menu == "users" ? "active" : "" %>
            <li class="nav-item dropdown text-center <%= active + hidden %>" style="min-width: 100px;">
                <a class="nav-link dropdown-toggle text-white fw-light py-3 px-3" href="#" data-bs-toggle="dropdown"
                   data-tippy-content="<%= lang('manage_users_hint') %>">
                    <i class="fas fa-users me-2"></i>
                    <%= lang('users') %>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <a class="dropdown-item" href="/providers">
                        <%= lang('providers') %>
                    </a>
                    <a class="dropdown-item" href="/secretaries">
                        <%= lang('secretaries') %>
                    </a>
                    <a class="dropdown-item" href="/admins">
                        <%= lang('admins') %>
                    </a>
                </div>
            </li>

            <% hidden = can?(:view, :system_settings) || can?(:view, :user_settings) ? "" : "d-none" %>
            <% active = active_menu == "system_settings" ? "active" : "" %>
            <li class="nav-item dropdown text-center <%= active + hidden %>" style="min-width: 100px;">
                <a class="nav-link dropdown-toggle text-white fw-light py-3 px-3" href="#" data-bs-toggle="dropdown"
                   data-tippy-content="<%= lang('settings_hint') %>">
                    <i class="fas fa-user me-2"></i>
                    <%= vars(:user_display_name) %>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <% if can?(:view, :system_settings) %>
                        <a class="dropdown-item" href="/general_settings">
                            <i class="fas fa-cogs me-2"></i>
                            <%= lang('settings') %>
                        </a>
                    <% end %>

                    <% if can?(:edit, :system_settings) %>
                        <a class="dropdown-item" href="/import">
                            <i class="fas fa-file-import me-2"></i>
                            <%= lang('manage_data') %>
                        </a>
                    <% end %>

                    <a class="dropdown-item" href="/account">
                        <i class="fas fa-user me-2"></i>
                        <%= lang('account') %>
                    </a>

                    <% if [ Role::ADMIN, Role::SECRETARY ].include?(session[:role_slug]) %>
                        <% unknown_unread = Message.unread.unknown_sender.count %>
                        <a class="dropdown-item" href="/unknown_inbox">
                            <i class="fas fa-inbox me-2"></i>
                            <%= lang('unknown_inbox') %>
                            <% if unknown_unread.positive? %>
                                <span class="badge bg-danger ms-1"><%= unknown_unread %></span>
                            <% end %>
                        </a>
                    <% end %>
                    <a class="dropdown-item" href="/about">
                        <i class="fas fa-info-circle me-2"></i>
                        <%= lang('about') %>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="/booking" target="_blank">
                        <i class="fas fa-external-link me-2"></i>
                        <%= lang('booking') %>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="/logout">
                        <i class="fas fa-sign-out me-2"></i>
                        <%= lang('log_out') %>
                    </a>
                </div>
            </li>
        </ul>
    </div>
</nav>

<div id="notification" style="display: none;"></div>

<div id="loading" class="position-fixed top-0 start-0 w-100 h-100" style="display: none; z-index: 999999; background: rgba(255, 255, 255, 0.75);">
    <div class="any-element animation is-loading d-block mx-auto">
        &nbsp;
    </div>
</div>
