<%# Port of EA components/matomo_analytics_script.php. Locals: matomo_analytics_url, matomo_analytics_site_id. %>
<% if matomo_analytics_url.present? %>

    <script>
        var _paq = window._paq = window._paq || [];
        /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
        _paq.push(["setDocumentTitle", document.domain + "/" + document.title]);
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        (function () {
            var u = "<%= matomo_analytics_url %>";
            _paq.push(['setTrackerUrl', u + 'matomo.php']);
            _paq.push(['setSiteId', '<%= matomo_analytics_site_id %>']);
            var d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
            g.async = true;
            g.src = u + 'matomo.js';
            s.parentNode.insertBefore(g, s);
        })();
    </script>

    <noscript>
        <p><img src="<%= matomo_analytics_url %>matomo.php?idsite=<%= matomo_analytics_site_id %>&amp;rec=1" style="border:0;" alt=""/></p>
    </noscript>

<% end %>
