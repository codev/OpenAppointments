<%# Port of EA components/appointments_modal.php. Locals: available_services,
    appointment_status_options, require_email,
    require_phone_number, require_address, require_city, require_zip_code, require_notes. %>
<div id="appointments-modal" class="modal fade">
    <div class="modal-dialog modal-dialog-centered modal-fullscreen-lg-down modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title"><%= lang('edit_appointment_title') %></h3>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="modal-message alert d-none"></div>

                <form>
                    <fieldset>
                        <h5 class="mb-3 fw-light"><%= lang('appointment_details_title') %></h5>

                        <input id="appointment-id" type="hidden">

                        <div class="row">
                            <div class="col-12 col-sm-6">
                                <div class="mb-3">
                                    <label for="select-service" class="form-label">
                                        <%= lang('service') %>
                                        <span class="text-danger">*</span>
                                    </label>
                                    <select id="select-service" class="required form-select">
                                        <%# Group services by category, only if at least one service has one. %>
                                        <% has_category = available_services.any? { |service| service["service_category_id"].present? } %>
                                        <% if has_category %>
                                            <% grouped_services = available_services.select { |service| service["service_category_id"].present? }
                                                                                    .group_by { |service| service["service_category_name"] } %>
                                            <% grouped_services["uncategorized"] = available_services.select { |service| service["service_category_id"].nil? } %>
                                            <% grouped_services.each do |key, group| %>
                                                <% next if group.empty? %>
                                                <optgroup label="<%= key != 'uncategorized' ? group.first['service_category_name'] : 'Uncategorized' %>">
                                                    <% group.each do |service| %>
                                                        <option value="<%= service['id'] %>"><%= service['name'] %></option>
                                                    <% end %>
                                                </optgroup>
                                            <% end %>
                                        <% else %>
                                            <% available_services.each do |service| %>
                                                <option value="<%= service['id'] %>"><%= service['name'] %></option>
                                            <% end %>
                                        <% end %>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label for="select-provider" class="form-label">
                                        <%= lang('provider') %>
                                        <span class="text-danger">*</span>
                                    </label>
                                    <select id="select-provider" class="required form-select"></select>
                                </div>

                                <div class="mb-3">
                                    <%= render "shared/color_selection", attributes: 'id="appointment-color"' %>
                                </div>

                                <div class="mb-3">
                                    <label for="appointment-location" class="form-label">
                                        <%= lang('location') %>
                                    </label>
                                    <input id="appointment-location" class="form-control">
                                </div>

                                <div class="mb-3">
                                    <label for="appointment-meeting-link" class="form-label">
                                        <%= lang('meeting_link') %>
                                    </label>
                                    <input id="appointment-meeting-link" class="form-control" placeholder="https://">
                                </div>

                                <div class="mb-3">
                                    <label for="appointment-status" class="form-label">
                                        <%= lang('status') %>
                                    </label>
                                    <select id="appointment-status" class="form-select">
                                        <% appointment_status_options.each do |appointment_status_option| %>
                                            <option value="<%= appointment_status_option %>">
                                                <%= appointment_status_option %>
                                            </option>
                                        <% end %>
                                    </select>
                                </div>
                            </div>

                            <div class="col-12 col-sm-6">
                                <div class="mb-3">
                                    <label for="start-datetime"
                                           class="form-label"><%= lang('start_date_time') %></label>
                                    <input id="start-datetime" class="required form-control">
                                </div>

                                <div class="mb-3">
                                    <label for="end-datetime" class="form-label"><%= lang('end_date_time') %></label>
                                    <input id="end-datetime" class="required form-control">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">
                                        <%= lang('timezone') %>
                                    </label>

                                    <div
                                        class="border rounded d-flex justify-content-between align-items-center bg-light timezone-info">
                                        <div class="border-end w-50 p-1 text-center">
                                            <small>
                                                <%= lang('provider') %>:
                                                <span class="provider-timezone">
                                                    -
                                                </span>
                                            </small>
                                        </div>
                                        <div class="w-50 p-1 text-center">
                                            <small>
                                                <%= lang('current_user') %>:
                                                <span>
                                                    <%= timezones[session[:timezone].presence || "UTC"] %>
                                                </span>
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="appointment-notes" class="form-label">
                                        <%= lang('notes') %>
                                        <% if require_notes %>
                                            <span class="text-danger">*</span>
                                        <% end %>
                                    </label>
                                    <textarea id="appointment-notes" class="<%= require_notes ? 'required' : '' %> form-control" rows="3"></textarea>
                                </div>

                            </div>
                        </div>
                    </fieldset>

                    <br>

                    <fieldset>
                        <h5 class="mb-3 fw-light">
                            <%= lang('customer_details_title') %>
                            <button id="new-customer" class="btn btn-outline-secondary btn-sm" type="button"
                                    data-tippy-content="<%= lang('clear_fields_add_existing_customer_hint') %>">
                                <i class="fas fa-plus-square me-2"></i>
                                <%= lang('new') %>
                            </button>
                            <button id="select-customer" class="btn btn-outline-secondary btn-sm" type="button"
                                    data-tippy-content="<%= lang('pick_existing_customer_hint') %>">
                                <i class="fas fa-hand-pointer me-2"></i>
                                <span>
                                    <%= lang('select') %>
                                </span>
                            </button>

                            <input id="filter-existing-customers"
                                   placeholder="<%= lang('type_to_filter_customers') %>"
                                   style="display: none;" class="input-sm form-control">
                        </h5>

                        <div id="existing-customers-list" style="display: none;"></div>

                        <input id="customer-id" type="hidden">

                        <div class="row">
                            <div class="col-12 col-sm-6">
                                <div class="mb-3">
                                    <label for="name" class="form-label">
                                        <%= lang('name') %>
                                        <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" id="name" class="required form-control" maxlength="220"/>
                                </div>

<% if display_email %>
                                    <div class="mb-3">
                                        <label for="email" class="form-label">
                                            <%= lang('email') %>
                                            <% if require_email %>
                                                <span class="text-danger">*</span>
                                            <% end %>
                                        </label>
                                        <input type="text" id="email"
                                               class="<%= require_email ? 'required' : '' %> form-control"
                                               maxlength="120"/>
                                    </div>
                                <% end %>

<% if display_phone_number %>
                                    <div class="mb-3">
                                        <label for="phone-number" class="form-label">
                                            <%= lang('phone_number') %>
                                            <% if require_phone_number %>
                                                <span class="text-danger">*</span>
                                            <% end %>
                                        </label>
                                        <input type="text" id="phone-number" maxlength="60"
                                               class="<%= require_phone_number ? 'required' : '' %> form-control"/>
                                    </div>
                                <% end %>

                                <div class="mb-3">
                                    <label class="form-label" for="language">
                                        <%= lang('language') %>
                                        <span class="text-danger" hidden>*</span>
                                    </label>
                                    <select id="language" class="form-select required">
                                        <% vars(:available_languages).each do |available_language| %>
                                            <option value="<%= available_language %>">
                                                <%= available_language.capitalize %>
                                            </option>
                                        <% end %>
                                    </select>
                                </div>

                                <%= render "shared/custom_fields" %>

                            </div>
                            <div class="col-12 col-sm-6">
<% if display_address %>
                                    <div class="mb-3">
                                        <label for="address" class="form-label">
                                            <%= lang('address') %>
                                            <% if require_address %>
                                                <span class="text-danger">*</span>
                                            <% end %>
                                        </label>
                                        <input type="text" id="address"
                                               class="<%= require_address ? 'required' : '' %> form-control"
                                               maxlength="120"/>
                                    </div>
                                <% end %>

<% if display_city %>
                                    <div class="mb-3">
                                        <label for="city" class="form-label">
                                            <%= lang('city') %>
                                            <% if require_city %>
                                                <span class="text-danger">*</span>
                                            <% end %>
                                        </label>
                                        <input type="text" id="city"
                                               class="<%= require_city ? 'required' : '' %> form-control"
                                               maxlength="120"/>
                                    </div>
                                <% end %>

<% if display_zip_code %>
                                    <div class="mb-3">
                                        <label for="zip-code" class="form-label">
                                            <%= lang('zip_code') %>
                                            <% if require_zip_code %>
                                                <span class="text-danger">*</span>
                                            <% end %>
                                        </label>
                                        <input type="text" id="zip-code"
                                               class="<%= require_zip_code ? 'required' : '' %> form-control"
                                               maxlength="120"/>
                                    </div>
                                <% end %>

                                <div class="mb-3">
                                    <label class="form-label" for="timezone">
                                        <%= lang('timezone') %>
                                        <span class="text-danger" hidden>*</span>
                                    </label>
                                    <%= render "shared/timezone_dropdown",
                                               attributes: 'id="timezone" class="form-select required"',
                                               grouped_timezones: vars(:grouped_timezones) %>
                                </div>

                                <div class="mb-3">
                                    <label for="customer-notes" class="form-label">
                                        <%= lang('notes') %>
                                    </label>
                                    <textarea id="customer-notes" rows="3" class="form-control"></textarea>
                                </div>

                            </div>
                        </div>
                    </fieldset>

                </form>
            </div>

            <div class="modal-footer">

                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <%= lang('cancel') %>
                </button>
                <button id="save-appointment" class="btn btn-primary">
                    <i class="fas fa-check-square me-2"></i>
                    <%= lang('save') %>
                </button>
            </div>
        </div>
    </div>
</div>

<% content_for :scripts do %>
    <%= ea_js "components/appointments_modal" %>
<% end %>
