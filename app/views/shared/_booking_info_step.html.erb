<%# Port of EA components/booking_info_step.php. Locals: display_*/require_* setting flags ("1"/"0"). %>
<div id="wizard-frame-3" class="wizard-frame p-3 p-md-4" style="display:none;">
    <div class="frame-container py-3" style="min-height: 500px;">

        <h2 class="frame-title fw-light text-center mb-4 text-muted"><%= lang('customer_information') %></h2>

        <div class="row frame-content">
            <div class="col-12 col-lg-6 field-col mx-auto">
                <% if display_first_name == "1" %>
                    <div class="mb-3">
                        <label for="first-name" class="form-label">
                            <%= lang('first_name') %>
                            <% if require_first_name == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <input type="text" id="first-name"
                               class="<%= require_first_name == "1" ? 'required' : '' %> form-control" maxlength="100"/>
                    </div>
                <% end %>

                <% if display_last_name == "1" %>
                    <div class="mb-3">
                        <label for="last-name" class="form-label">
                            <%= lang('last_name') %>
                            <% if require_last_name == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <input type="text" id="last-name"
                               class="<%= require_last_name == "1" ? 'required' : '' %> form-control" maxlength="120"/>
                    </div>
                <% end %>

                <% if display_email == "1" %>
                    <div class="mb-3">
                        <label for="email" class="form-label">
                            <%= lang('email') %>
                            <% if require_email == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <input type="text" id="email"
                               class="<%= require_email == "1" ? 'required' : '' %> form-control" maxlength="120"/>
                    </div>
                <% end %>

                <% if display_phone_number == "1" %>
                    <div class="mb-3">
                        <label for="phone-number" class="form-label">
                            <%= lang('phone_number') %>
                            <% if require_phone_number == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <input type="text" id="phone-number" maxlength="60"
                               class="<%= require_phone_number == "1" ? 'required' : '' %> form-control"/>
                    </div>
                <% end %>

                <%= render "shared/custom_fields" %>

            </div>

            <div class="col-12 col-lg-6 field-col mx-auto">
                <% if display_address == "1" %>
                    <div class="mb-3">
                        <label for="address" class="form-label">
                            <%= lang('address') %>
                            <% if require_address == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <input type="text" id="address" class="<%= require_address == "1" ? 'required' : '' %> form-control"
                               maxlength="120"/>
                    </div>
                <% end %>
                <% if display_city == "1" %>
                    <div class="mb-3">
                        <label for="city" class="form-label">
                            <%= lang('city') %>
                            <% if require_city == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <input type="text" id="city" class="<%= require_city == "1" ? 'required' : '' %> form-control"
                               maxlength="120"/>
                    </div>
                <% end %>
                <% if display_zip_code == "1" %>
                    <div class="mb-3">
                        <label for="zip-code" class="form-label">
                            <%= lang('zip_code') %>
                            <% if require_zip_code == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <input type="text" id="zip-code" class="<%= require_zip_code == "1" ? 'required' : '' %> form-control"
                               maxlength="120"/>
                    </div>
                <% end %>
                <% if display_notes == "1" %>
                    <div class="mb-3">
                        <label for="notes" class="form-label">
                            <%= lang('notes') %>
                            <% if require_notes == "1" %>
                                <span class="text-danger">*</span>
                            <% end %>
                        </label>
                        <textarea id="notes" maxlength="500"
                                  class="<%= require_notes == "1" ? 'required' : '' %> form-control" rows="1"></textarea>
                    </div>
                <% end %>

                <% unless vars(:manage_mode) %>
                <div class="mb-3">
                    <div class="form-check">
                        <input type="checkbox" id="remember-me" class="form-check-input">
                        <label for="remember-me" class="form-check-label">
                            <%= lang('remember_me') %>
                        </label>
                    </div>
                    <div class="form-text text-muted small">
                        <%= lang('remember_me_hint') %>
                    </div>
                </div>
                <% end %>

            </div>

        </div>
    </div>

    <div class="command-buttons text-center my-3 mx-auto d-md-flex justify-content-md-between">
        <button type="button" id="button-back-3" class="btn button-back btn-outline-secondary" style="min-width: 120px; margin-right: 10px;"
                data-step_index="3">
            <i class="fas fa-chevron-left me-2"></i>
            <%= lang('back') %>
        </button>
        <button type="button" id="button-next-3" class="btn button-next btn-dark" style="min-width: 120px; margin-right: 10px;"
                data-step_index="3">
            <%= lang('next') %>
            <i class="fas fa-chevron-right ms-2"></i>
        </button>
    </div>
</div>
