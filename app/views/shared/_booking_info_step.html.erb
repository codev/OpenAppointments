<%# Port of EA components/booking_info_step.php. Locals: display_*/require_* setting flags ("1"/"0"). %>
<div id="wizard-frame-4" class="wizard-frame p-3 p-md-4" style="display:none;">
    <div class="frame-container py-3">

        <h2 class="frame-title fw-light text-center mb-4 text-muted"><%= lang('customer_information') %></h2>

        <div class="row frame-content">
            <div class="col-12 col-lg-6 mb-3">
                <label for="name" class="form-label">
                    <%= lang('name') %>
                    <span class="text-danger">*</span>
                </label>
                <input type="text" id="name" class="required form-control" maxlength="220"/>
            </div>

            <% if display_email == "1" %>
                <div class="col-12 col-lg-6 mb-3">
                    <label for="email" class="form-label">
                        <%= lang('email') %>
                        <% if require_email == "1" %>
                            <span class="text-danger">*</span>
                        <% end %>
                    </label>
                    <input type="text" id="email"
                           class="<%= require_email == "1" ? 'required' : '' %> form-control" maxlength="120"/>
                </div>
            <% end %>

            <% if display_phone_number == "1" %>
                <div class="col-12 col-lg-6 mb-3">
                    <label for="phone-number" class="form-label">
                        <%= lang('phone_number') %>
                        <% if require_phone_number == "1" %>
                            <span class="text-danger">*</span>
                        <% end %>
                    </label>
                    <input type="text" id="phone-number" maxlength="60"
                           class="<%= require_phone_number == "1" ? 'required' : '' %> form-control"/>
                </div>
            <% end %>

            <% if display_address == "1" %>
                <div class="col-12 col-lg-6 mb-3">
                    <label for="address" class="form-label">
                        <%= lang('address') %>
                        <% if require_address == "1" %>
                            <span class="text-danger">*</span>
                        <% end %>
                    </label>
                    <input type="text" id="address" class="<%= require_address == "1" ? 'required' : '' %> form-control"
                           maxlength="120"/>
                </div>
            <% end %>
            <% if display_city == "1" %>
                <div class="col-12 col-lg-6 mb-3">
                    <label for="city" class="form-label">
                        <%= lang('city') %>
                        <% if require_city == "1" %>
                            <span class="text-danger">*</span>
                        <% end %>
                    </label>
                    <input type="text" id="city" class="<%= require_city == "1" ? 'required' : '' %> form-control"
                           maxlength="120"/>
                </div>
            <% end %>
            <% if display_zip_code == "1" %>
                <div class="col-12 col-lg-6 mb-3">
                    <label for="zip-code" class="form-label">
                        <%= lang('zip_code') %>
                        <% if require_zip_code == "1" %>
                            <span class="text-danger">*</span>
                        <% end %>
                    </label>
                    <input type="text" id="zip-code" class="<%= require_zip_code == "1" ? 'required' : '' %> form-control"
                           maxlength="120"/>
                </div>
            <% end %>

            <%= render "shared/custom_fields", col_class: "col-12 col-lg-6" %>

            <% if display_notes == "1" %>
                <div class="col-12 mb-3">
                    <label for="notes" class="form-label">
                        <%= lang('notes') %>
                        <% if require_notes == "1" %>
                            <span class="text-danger">*</span>
                        <% end %>
                    </label>
                    <textarea id="notes" maxlength="500"
                              class="<%= require_notes == "1" ? 'required' : '' %> form-control" rows="1"></textarea>
                </div>
            <% end %>

            <% unless vars(:manage_mode) %>
                <div class="col-12 mb-3">
                    <div class="form-check">
                        <input type="checkbox" id="remember-me" class="form-check-input">
                        <label for="remember-me" class="form-check-label">
                            <%= lang('remember_me') %>
                        </label>
                    </div>
                    <div class="form-text text-muted small">
                        <%= lang('remember_me_hint') %>
                    </div>
                </div>
            <% end %>

        </div>

        <div id="form-message" class="alert alert-danger text-center" role="alert" style="display:none;"></div>
    </div>

    <div class="command-buttons text-center my-3 mx-auto d-md-flex justify-content-md-between">
        <button type="button" id="button-back-4" class="btn button-back btn-outline-secondary"
                data-step_index="4">
            <i class="fas fa-chevron-left me-2"></i>
            <%= lang('back') %>
        </button>
        <button type="button" id="button-next-4" class="btn button-next btn-dark"
                data-step_index="4">
            <%= lang('next') %>
            <i class="fas fa-chevron-right ms-2"></i>
        </button>
    </div>
</div>
