<%# Port of EA pages/google_analytics_settings.php. %>
<div id="google-analytics-settings-page" class="container backend-page py-3">
    <div class="row">
        <div class="col-sm-3">
            <%= render "shared/settings_nav" %>
        </div>
        <div id="google-analytics-settings" class="col-sm-9">
            <form>
                <fieldset>
                    <div class="d-flex justify-content-between align-items-center border-bottom mb-4 py-2">
                        <h4 class="mb-0 fw-light">
                            <%= lang('google_analytics') %>
                        </h4>

                        <div>
                            <a href="/integrations" class="btn btn-outline-primary me-2">
                                <i class="fas fa-chevron-left me-2"></i>
                                <%= lang('back') %>
                            </a>

                            <% if can?(:edit, :system_settings) %>
                                <button type="button" id="save-settings" class="btn btn-primary">
                                    <i class="fas fa-check-square me-2"></i>
                                    <%= lang('save') %>
                                </button>
                            <% end %>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label class="form-label" for="google-analytics-code">
                                    <%= lang('google_analytics_code') %>
                                </label>
                                <input id="google-analytics-code" placeholder="G-XXXXXXXXXX"
                                       class="form-control" data-field="google_analytics_code">
                                <div class="form-text text-muted">
                                    <small>
                                        <%= lang('google_analytics_code_hint') %>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                </fieldset>
            </form>
        </div>
    </div>
</div>

<% content_for :scripts do %>
    <%= ea_js "http/google_analytics_settings_http_client", "pages/google_analytics_settings" %>
<% end %>
